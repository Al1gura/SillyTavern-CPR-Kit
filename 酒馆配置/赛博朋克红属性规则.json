    { "name": "技术", "formula": "1d10", "range": [2, 10] },
    { "name": "酷",   "formula": "1d10", "range": [2, 10] },
    { "name": "意志", "formula": "1d10", "range": [2, 10] },
    { "name": "运气", "formula": "1d10", "range": [2, 10] },
    { "name": "移动", "formula": "1d10", "range": [2, 10] },
    { "name": "体格", "formula": "1d10", "range": [2, 10] },
